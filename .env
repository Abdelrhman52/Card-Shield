# =============================================================================
# CardShield — Environment Variables Template
# Copy this file to .env and fill in all values before running docker-compose.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# MySQL — root + monitoring DB
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_MONITORING_DB=cardshield_monitoring
MYSQL_MONITORING_USER=cardshield
MYSQL_MONITORING_PASSWORD=changeme_monitoring

# MySQL — Airflow metadata DB (created by airflow_db_init.sql)
MYSQL_AIRFLOW_DB=airflow
MYSQL_AIRFLOW_USER=airflow
MYSQL_AIRFLOW_PASSWORD=changeme_airflow

# -----------------------------------------------------------------------------
# Airflow
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# -----------------------------------------------------------------------------
AIRFLOW_FERNET_KEY=tPk3LHak6EbNW5oWNXI1riBUthMphec_tOFEBKJWkr0=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=123456

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_TRANSACTIONS=card-transactions
KAFKA_TOPIC_FRAUD_ALERTS=fraud-alerts
KAFKA_CONSUMER_GROUP=cardshield-flink-group

# -----------------------------------------------------------------------------
# Schema Registry
# -----------------------------------------------------------------------------
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# -----------------------------------------------------------------------------
# Producer settings
# -----------------------------------------------------------------------------
PRODUCER_CSV_PATH=/data/Fraud.csv
PRODUCER_RATE_LIMIT=500          # messages per second (0 = unlimited)
PRODUCER_BATCH_SIZE=100
PRODUCER_LINGER_MS=10

# -----------------------------------------------------------------------------
# HDFS
# -----------------------------------------------------------------------------
HDFS_NAMENODE_URL=hdfs://namenode:8020
HDFS_ARCHIVE_BASE=/cardshield/transactions
HDFS_HBASE_BACKUP_BASE=/cardshield/hbase-backups

# -----------------------------------------------------------------------------
# HBase
# -----------------------------------------------------------------------------
HBASE_HOST=hbase
HBASE_PORT=9090
HBASE_ZOOKEEPER_QUORUM=hbase
HBASE_ZOOKEEPER_PORT=2182

# -----------------------------------------------------------------------------
# Flink
# -----------------------------------------------------------------------------
FLINK_JOBMANAGER_HOST=flink-jobmanager
FLINK_JOBMANAGER_PORT=8081
FLINK_CHECKPOINT_INTERVAL_MS=30000

# -----------------------------------------------------------------------------
# Alerting (Slack — optional)
# Replace with real webhook URL or leave empty to disable
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ

# -----------------------------------------------------------------------------
# Email / SMTP (for Airflow failure alerts)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=cardshield-alerts@yourdomain.com
